# ==============================================================
# Kora Technologies - Revenue Intelligence Platform
# Example environment configuration.
# Copy this file to `.env` and replace values as needed.
# ==============================================================

# --------------------------------------------------------------
# Application
# --------------------------------------------------------------
APP_NAME="Kora Revenue Intelligence Platform"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=true
SECRET_KEY="generate_a_real_secret_here"

# --------------------------------------------------------------
# JWT
# --------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --------------------------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kora_db
POSTGRES_USER=kora_user
POSTGRES_PASSWORD=kora_dev_password_123

# --------------------------------------------------------------
# AI (OpenAI)
# --------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------------------------
# API
# --------------------------------------------------------------
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --------------------------------------------------------------
# Logging
# --------------------------------------------------------------
LOG_LEVEL=INFO